---
import { useTranslations, getLocaleFromUrl } from '@/i18n/utils';
const t = useTranslations(getLocaleFromUrl(Astro.url));
---

<button
  type="button"
  data-theme-toggle
  class="grid h-9 w-9 place-items-center rounded-lg border border-border text-muted transition hover:text-accent hover:border-accent/50"
  aria-label={t('theme.toggle')}
  title={t('theme.toggle')}
>
  <!-- 月亮（暗色时显示） -->
  <svg
    class="hidden h-[18px] w-[18px] dark:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  <!-- 太阳（浅色时显示） -->
  <svg
    class="block h-[18px] w-[18px] dark:hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
    ></path>
  </svg>
</button>
