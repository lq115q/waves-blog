---
import type { Locale } from '@/consts';
import { useTranslations } from '@/i18n/utils';
import Search from 'astro-pagefind/components/Search';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div class="mx-auto max-w-3xl px-4 sm:px-6 py-12">
  <h1 class="text-3xl font-semibold tracking-tight text-fg">{t('search.title')}</h1>
  <p class="mt-2 text-muted">{t('search.placeholder')}</p>

  <div class="mt-8">
    <Search
      id="search"
      className="pagefind-ui"
      uiOptions={{ showImages: false, showSubResults: true }}
    />
  </div>
</div>
