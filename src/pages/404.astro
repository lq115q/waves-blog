---
import { useTranslations, localizePath } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

const locale = 'zh';
const t = useTranslations(locale);
---

<BaseLayout title={t('notFound.title')} description={t('notFound.desc')} locale={locale}>
  <section class="mx-auto max-w-2xl px-4 sm:px-6 py-24 text-center">
    <p class="font-mono text-sm uppercase tracking-wider text-accent">404</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-fg">
      {t('notFound.title')}
    </h1>
    <p class="mt-4 text-muted">{t('notFound.desc')}</p>
    <a href={localizePath('/', locale)} class="mt-8 inline-block link-accent">
      &larr; {t('notFound.back')}
    </a>
  </section>
</BaseLayout>
