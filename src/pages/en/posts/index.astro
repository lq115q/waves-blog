---
/**
 * 英文文章列表页：/en/posts
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPosts } from '@/lib/posts';
import { useTranslations } from '@/i18n/utils';
import { SITE_META } from '@/consts';

const locale = 'en' as const;
const t = useTranslations(locale);
const posts = await getPosts(locale);
const title = t('list.title');
const description = SITE_META[locale].description;
---

<BaseLayout title={title} description={description} locale={locale}>
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold tracking-tight text-fg sm:text-4xl">{title}</h1>
      <p class="mt-2 font-mono text-sm text-faint">{t('list.count', { n: posts.length })}</p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-muted">{t('list.empty')}</p>
      ) : (
        <div class="space-y-4">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
