---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TagPage from '@/components/sections/TagPage.astro';
import { getAllTags, getPostsByTag } from '@/lib/posts';
import { useTranslations } from '@/i18n/utils';

export async function getStaticPaths() {
  const tags = await getAllTags('en');
  return tags.map(({ tag }) => ({ params: { tag }, props: { tag } }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const posts = await getPostsByTag('en', tag);
const t = useTranslations('en');
---

<BaseLayout title={t('tag.heading', { tag })} locale="en">
  <TagPage locale="en" tag={tag} posts={posts} />
</BaseLayout>
